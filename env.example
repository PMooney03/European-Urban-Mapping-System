# Environment Variables Template
# Copy this file to .env and update with your actual values
# DO NOT commit .env file to version control

# ============================================
# Database Configuration (PostgreSQL/PostGIS)
# ============================================
POSTGRES_DB=european_mapping_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pierce
POSTGRES_HOST=postgis
POSTGRES_PORT=5432

# ============================================
# Django Application Settings
# ============================================
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-get_random_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================
# PgAdmin Configuration
# ============================================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# ============================================
# Static Files Configuration
# ============================================
STATIC_ROOT=/app/staticfiles
STATIC_URL=/static/

# ============================================
# GDAL/GEOS Library Paths (Windows Development Only)
# Uncomment and adjust paths for your Conda environment
# ============================================
# GDAL_LIBRARY_PATH=C:/Users/YourUsername/miniconda3/envs/geo/Library/bin/gdal.dll
# GEOS_LIBRARY_PATH=C:/Users/YourUsername/miniconda3/envs/geo/Library/bin/geos_c.dll

# ============================================
# CORS Configuration (Development)
# ============================================
CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# Notes:
# - Generate Django secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# - Use strong passwords for production
# - Set DEBUG=False in production
# - Configure specific ALLOWED_HOSTS in production
# - Adjust GDAL/GEOS paths based on your system
# ============================================




